---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lents,Portland, Oregon|Welcome To Paradise">
    <nav class="town-nav">
        <span>History</span> • <span>Tourism</span> • <span>Community</span>
    </nav>

    <main class="container">
        <section class="hero">
            <h1>Welcome To Paradise</h1>
            <p class="tagline">"Welcome To Paradise"</p>
            <div class="image-wrapper">
    <img src="/town-photo.jpg" alt="Lents Street" class="main-photo" />
    
    <div class="hidden-killer" style="background-image: url('/IMG_2280.webp');"></div>
</div>
            
            </div>
        </section>

        <section class="news">
            <h3>Local News</h3>
            <div class="article">
                <h4>Missing Persons Alert</h4>
                <p>Police are searching for three individuals last seen near the trailer park...</p>
            </div>
        </section>
    </main>
</Layout>

<style>
    body {
        background-color: #f4f1ea; /* Faded paper color */
        color: #333;
        font-family: 'Times New Roman', serif;
        margin: 0;
    }

    .town-nav {
        background: #2c3e50;
        color: white;
        padding: 10px;
        text-align: center;
        font-size: 0.8rem;
        text-transform: uppercase;
    }

    .container {
        padding: 20px;
        max-width: 600px;
        margin: auto;
    }

    h1 {
        color: #4a4a4a;
        text-align: center;
        border-bottom: 1px solid #ccc;
    }

    .tagline {
        text-align: center;
        font-style: italic;
        margin-top: -10px;
        color: #777;
    }

    .image-wrapper {
        position: relative;
        margin: 20px 0;
        border: 5px solid white;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .main-photo {
        width: 100%;
        display: block;
        transition: filter 0.5s ease;
    }

    /* THE STRANGERS EFFECT: The mask only appears when you long-press or hover */
    .image-wrapper:active .main-photo {
        filter: brightness(0.3) contrast(1.2);
    }

    .image-wrapper:active .hidden-killer {
        opacity: 1;
    }

    .hidden-killer {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: url('/mask.png'); /* Your bunny mask with transparent BG */
        background-size: 40%;
        background-repeat: no-repeat;
        background-position: 80% 50%; /* Tucked in the corner */
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .news {
        background: white;
        padding: 15px;
        border: 1px solid #ddd;
    }
</style>
